{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "greentea",
  "version": "0.1.0",
  "identifier": "org.archbang.greentea",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "greentea",
        "width": 1100,
        "height": 720,
        "minWidth": 480,
        "minHeight": 320,
        "transparent": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["appimage", "deb"],
    "icon": []
  }
}
